[Unit]
Description=Goose Relay
After=network.target
Wants=network.target

[Service]
Type=simple
User=root
Group=root

ExecStart=/root/GooseRelayVPN-client-v1.5.0-linux-amd64/goose-client -config /root/GooseRelayVPN-client-v1.5.0-linux-amd64/client_config.json

Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
