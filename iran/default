server {
    listen 127.0.0.1:2083 ssl;
    server_name p.ashkan1998.ir;

    ssl_certificate /etc/letsencrypt/live/p.ashkan1998.ir/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/p.ashkan1998.ir/privkey.pem;

    location /webhook/ {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_redirect off;
    }

    location / {
        return 301 https://cloud.irancell.ir$request_uri;
    }
}
